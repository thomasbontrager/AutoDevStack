# AutoDevStack Deployment Stack – Environment Variables
# Copy this file to .env and fill in the values

# JWT secret used by the API server
JWT_SECRET=changeme-jwt-secret

# Shared secret between the API and the build server
BUILD_SECRET=changeme-build-secret

# Base domain for project subdomains (e.g. myplatform.com → app.myplatform.com)
# Use "localhost" for local development
SUBDOMAIN_BASE=localhost
