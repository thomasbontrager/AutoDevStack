# ── ColiCode Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# GitHub personal access token (fine-grained or classic)
# Required scopes: repo (read access to code, pull requests, issues)
GITHUB_TOKEN=ghp_yourTokenHere

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-yourKeyHere

# Model to use for AI suggestions (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# API server settings
PORT=3100
API_SECRET=change_me_in_production

# Optional: GitHub App credentials (if using a GitHub App instead of PAT)
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY_PATH=./certs/private-key.pem
# GITHUB_INSTALLATION_ID=
