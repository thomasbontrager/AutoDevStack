# =============================================================================
# AI App Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---- Database ---------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aiapp"

# ---- AI Provider ------------------------------------------------------------
# Set to "openai" or "anthropic"
AI_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ---- AI Model Settings ------------------------------------------------------
AI_MODEL=gpt-4o-mini
# AI_MODEL=claude-3-haiku-20240307  # Use this for Anthropic
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024

# Optional: Custom system prompt
# AI_SYSTEM_PROMPT=You are a helpful assistant specialized in...

# ---- Service URLs -----------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:5000

# Public env vars (accessible in Next.js frontend)
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:5000

# ---- Server Ports -----------------------------------------------------------
PORT=4000
AI_SERVICE_PORT=5000

# ---- LangChain (optional, for tracing) --------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=my-ai-app
