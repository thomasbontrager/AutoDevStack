{
  "name": "backend",
  "version": "0.1.0",
  "description": "Express API server with Prisma and PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push --schema ../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../prisma/schema.prisma",
    "db:studio": "prisma studio --schema ../prisma/schema.prisma",
    "postinstall": "prisma generate --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
