# Environment Variables for AI Swarm Platform
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token with repo + workflow scopes
GH_TOKEN=ghp_...

# ── Deployment ────────────────────────────────────────────────────────────────
# SSH private key path used by deploy-cloud.sh
DEPLOY_KEY=~/.ssh/id_rsa

# Remote server details
SERVER_HOST=your.server.ip.or.hostname
SERVER_USER=ubuntu

# Custom domain (optional — used in deploy-cloud.sh output)
DOMAIN=swarm.example.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=swarmpassword

# ── Swarm tuning ─────────────────────────────────────────────────────────────
# Number of concurrent AI agents per swarm run
AGENT_COUNT=3

# Dashboard port
PORT=4000

# ── OpenAI tuning (optional) ──────────────────────────────────────────────────
# Model to use for AI generation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Sampling temperature 0–2 (default: 0.6)
OPENAI_TEMPERATURE=0.6
# Max tokens per completion (default: 800)
OPENAI_MAX_TOKENS=800

# ── Dashboard tuning (optional) ───────────────────────────────────────────────
# How often the dashboard broadcasts live updates in ms (default: 30000)
BROADCAST_INTERVAL_MS=30000
# ── Deployment environment ────────────────────────────────────────────────────
# One of: dev | prod
DEPLOY_ENV=dev
