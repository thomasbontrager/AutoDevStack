# AI Swarm Platform Environment Configuration

# ==============================================================================
# AI Provider
# ==============================================================================
OPENAI_API_KEY=your-openai-api-key-here

# ==============================================================================
# GitHub Configuration
# ==============================================================================
# Personal Access Token with repo, workflow, and admin:org permissions
GH_TOKEN=your-github-token-here

# Your GitHub username (used for creating repos)
GH_USERNAME=your-github-username

# ==============================================================================
# Server Configuration
# ==============================================================================
NODE_ENV=development
PORT=4000

# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_DB=swarm
POSTGRES_USER=swarm
POSTGRES_PASSWORD=swarm_password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ==============================================================================
# Cloud Deployment (Optional)
# ==============================================================================
# Remote server details for cloud deployment
SERVER_HOST=
SERVER_USER=
DOMAIN=
DEPLOY_KEY=

# ==============================================================================
# Swarm Configuration (Optional)
# ==============================================================================
# Override default swarm settings
# MAX_AGENTS=5
# SWARM_INTERVAL=10000
# AUTO_RESTART=true

# ==============================================================================
# Monitoring & Analytics (Optional)
# ==============================================================================
# MONITORING_ENABLED=true
# ALERT_EMAIL=
# SLACK_WEBHOOK_URL=
